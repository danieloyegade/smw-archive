---
import { projects } from '../data/projects';
const base = import.meta.env.BASE_URL;
const publicBase = base.endsWith('/') ? base : `${base}/`;
const asset = (path: string) => `${publicBase}${path.replace(/^\//, '')}`;
const serializedProjects = projects.map((project) => ({
  ...project,
  image: asset(project.image),
}));
---

<section class="archive-shell">
  <header class="archive-header">
    <div>
      <p class="brand">SEE MY WORLD</p>
      <p class="brand-sub">ARCHIVE</p>
    </div>
    <div class="header-note">ROTATE THE GLOBE TO EXPLORE</div>
  </header>

  <div class="stage">
    <div class="caption" aria-live="polite">
      <div class="caption-title" data-caption-title>DRAG TO EXPLORE THE ARCHIVE</div>
      <div class="caption-meta" data-caption-meta></div>
    </div>
    <canvas id="globe-canvas" aria-label="Interactive archive globe"></canvas>
  </div>
</section>

<script type="application/json" id="archive-project-data" set:html={JSON.stringify(serializedProjects)}></script>
<script type="module" src={`${publicBase}archive-globe.js`}></script>

<style>
  .archive-shell {
    position: relative;
    min-height: 100svh;
    background:
      radial-gradient(circle at 50% 44%, rgba(255, 46, 46, 0.08), transparent 28%),
      radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.04), transparent 36%),
      var(--bg);
    overflow: hidden;
  }

  .archive-header {
    position: absolute;
    left: 0;
    top: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 1.5rem 1.6rem;
    z-index: 2;
    pointer-events: none;
    letter-spacing: 0.26em;
  }

  .brand,
  .brand-sub,
  .header-note,
  .caption-title,
  .caption-meta {
    margin: 0;
    text-transform: uppercase;
  }

  .brand {
    font-size: 0.93rem;
    font-weight: 700;
  }

  .brand-sub {
    margin-top: 0.22rem;
    font-size: 0.72rem;
    color: var(--muted);
  }

  .header-note {
    margin-top: 0.16rem;
    font-size: 0.72rem;
    color: var(--muted);
  }

  .stage {
    position: relative;
    width: 100%;
    height: 100svh;
  }

  #globe-canvas {
    width: 100%;
    height: 100%;
    display: block;
    touch-action: none;
  }

  .caption {
    position: absolute;
    left: 50%;
    bottom: 2.1rem;
    transform: translateX(-50%);
    z-index: 2;
    text-align: center;
    pointer-events: none;
    width: min(92vw, 38rem);
    text-shadow: 0 1px 14px rgba(0, 0, 0, 0.8);
  }

  .caption-title {
    font-size: clamp(1rem, 1.6vw, 1.45rem);
    font-weight: 700;
    letter-spacing: 0.3em;
  }

  .caption-meta {
    margin-top: 0.45rem;
    font-size: 0.84rem;
    color: var(--muted);
    letter-spacing: 0.24em;
  }

  @media (max-width: 760px) {
    .archive-header {
      padding: 1rem 1rem;
    }

    .header-note {
      display: none;
    }

    .caption {
      bottom: 1.4rem;
      width: calc(100vw - 2rem);
    }

    .caption-title {
      font-size: 0.95rem;
      letter-spacing: 0.22em;
    }

    .caption-meta {
      font-size: 0.73rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #globe-canvas {
      scroll-behavior: auto;
    }
  }
</style>
