---
const {
  title = 'See My World Archive',
  description = 'Interactive archive globe for See My World.',
} = Astro.props;
const base = import.meta.env.BASE_URL;
const publicBase = base.endsWith('/') ? base : `${base}/`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${publicBase}site-favicon.svg`} />
    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #050505;
        --bg-soft: #0b0b0b;
        --panel: rgba(13, 13, 13, 0.88);
        --text: #f4f1ec;
        --muted: rgba(244, 241, 236, 0.66);
        --line: rgba(255, 53, 53, 0.92);
        --line-soft: rgba(255, 53, 53, 0.32);
        --shadow: rgba(0, 0, 0, 0.55);
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        width: 100%;
        min-height: 100%;
        background: var(--bg);
        color: var(--text);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      }

      body {
        overflow-x: hidden;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
      }
    </style>
  </head>
  <body data-base={publicBase}>
    <slot />
  </body>
</html>
